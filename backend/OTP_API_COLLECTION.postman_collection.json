{
  "info": {
    "name": "AI TrafficCam - OTP Verification System",
    "description": "Complete API collection for testing OTP-based email verification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Signup (with OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Test@123\",\n  \"gender\": \"male\",\n  \"phone\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/signup",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "signup"]
            },
            "description": "Create new account and send OTP to email"
          },
          "response": []
        },
        {
          "name": "2. Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/verify-otp",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "verify-otp"]
            },
            "description": "Verify OTP and activate account. Returns JWT tokens."
          },
          "response": []
        },
        {
          "name": "3. Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/resend-otp",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "resend-otp"]
            },
            "description": "Resend OTP to email (60 second cooldown)"
          },
          "response": []
        },
        {
          "name": "4. Get OTP Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/otp-status",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "otp-status"]
            },
            "description": "Check if user has active OTP and remaining time/attempts"
          },
          "response": []
        },
        {
          "name": "5. Login (Existing User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Test@123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with verified account"
          },
          "response": []
        },
        {
          "name": "6. Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/me",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "me"]
            },
            "description": "Get current user profile (requires authentication)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Edge Cases & Error Testing",
      "item": [
        {
          "name": "Test: Wrong OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"otp\": \"000000\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/verify-otp",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "verify-otp"]
            },
            "description": "Expected: 400 error with remaining attempts"
          },
          "response": []
        },
        {
          "name": "Test: Duplicate Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Test@123\",\n  \"gender\": \"male\",\n  \"phone\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/signup",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "signup"]
            },
            "description": "Expected: 409 error if email already verified"
          },
          "response": []
        },
        {
          "name": "Test: Invalid Gender",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Test@123\",\n  \"gender\": \"female\",\n  \"phone\": \"+919876543210\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/signup",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "signup"]
            },
            "description": "Expected: 400 error (only male users allowed per requirements)"
          },
          "response": []
        },
        {
          "name": "Test: Rate Limit Resend",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/resend-otp",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "resend-otp"]
            },
            "description": "Send this twice quickly. Expected: 429 error on second request"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5001/api/v1",
      "type": "string"
    },
    {
      "key": "ACCESS_TOKEN",
      "value": "",
      "type": "string"
    }
  ]
}
