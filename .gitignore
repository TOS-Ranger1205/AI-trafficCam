__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/
.eggs/
*.egg-info/
*.egg

# Build outputs
dist/
build/
*.js.map

# Environment files
.env
.env.local
.env.*.local
!.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
.nyc_output/
.coverage
htmlcov/

# Uploads (local development)
uploads/
evidence/
temp/

# AI Models (downloaded on demand)
*.pt
*.pth
