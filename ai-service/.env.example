# AI Service Configuration
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Backend API
BACKEND_URL=http://localhost:5000
BACKEND_API_KEY=ai-trafficcam-backend-key

# AI Model Settings
MODEL_PATH=./models
YOLO_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.75
NMS_THRESHOLD=0.4

# Video Processing
MAX_VIDEO_SIZE=500MB
FRAME_SKIP=5
OUTPUT_RESOLUTION=720p
SAVE_EVIDENCE_FRAMES=true

# License Plate OCR
OCR_LANGUAGES=en
PLATE_PATTERN_REGION=india

# GPU Settings
USE_GPU=false
GPU_DEVICE=0

# Storage
UPLOAD_DIR=./uploads
EVIDENCE_DIR=./evidence
TEMP_DIR=./temp

# Rate Limiting
MAX_CONCURRENT_PROCESSING=5
QUEUE_SIZE=100

# Logging
LOG_DIR=./logs
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30
